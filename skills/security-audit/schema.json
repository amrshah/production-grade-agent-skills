{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "oneOf": [
    {
      "type": "object",
      "properties": {
        "status": { "type": "string", "enum": ["success"] },
        "data": {
          "type": "object",
          "properties": {
            "vulnerabilities": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "id": { "type": "string", "pattern": "^SEC-[0-9]{3}$"},
                  "type": { "type": "string" },
                  "severity": { "type": "string", "enum": ["high", "critical"] },
                  "location": { "type": "string", "pattern": "^.+:\\d+$" },
                  "owasp_mapping": { "type": "string", "pattern": "^A[0-9]{2}:2021-.+$" },
                  "fix": { "type": "string", "minLength": 20 }
                },
                "required": ["id", "type", "severity", "location", "owasp_mapping", "fix"]
              }
            }
          },
          "required": ["vulnerabilities"]
        }
      },
      "required": ["status", "data"]
    },
    {
      "type": "object",
      "properties": {
        "status": { "type": "string", "enum": ["failed"] },
        "reason": { "type": "string" },
        "retryable": { "type": "boolean" },
        "stage": { "type": "string", "enum": ["security-audit"] },
        "attempt": { "type": "integer", "minimum": 1 }
      },
      "required": ["status", "reason", "retryable", "stage", "attempt"]
    }
  ]
}
