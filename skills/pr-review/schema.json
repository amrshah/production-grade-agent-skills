{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "oneOf": [
    {
      "type": "object",
      "properties": {
        "status": { "type": "string", "enum": ["success"] },
        "data": {
          "type": "object",
          "properties": {
            "approval": { "type": "boolean" },
            "issues": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                   "id": {"type":"string", "pattern":"^PRR-[0-9]{3}$"},
                   "severity": {"type":"string", "enum":["low","medium","high","blocker"]},
                   "location": {"type":"string", "pattern":"^.+:\\d+$"},
                   "explanation": {"type":"string", "maxLength": 200},
                   "fix": {"type":"string", "minLength": 5}
                },
                "required": ["id","severity","location","explanation","fix"]
              }
            }
          },
          "required": ["approval", "issues"]
        }
      },
      "required": ["status", "data"]
    },
    {
      "type": "object",
      "properties": {
        "status": { "type": "string", "enum": ["failed"] },
        "reason": { "type": "string" },
        "retryable": { "type": "boolean" },
        "stage": { "type": "string", "enum": ["pr-review"] },
        "attempt": { "type": "integer", "minimum": 1 }
      },
      "required": ["status", "reason", "retryable", "stage", "attempt"]
    }
  ]
}
