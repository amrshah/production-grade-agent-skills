{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "oneOf": [
    {
      "type": "object",
      "properties": {
        "status": { "type": "string", "enum": ["success"] },
        "data": {
          "type": "object",
          "properties": {
            "issues": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "id": { "type": "string", "pattern": "^CI-[0-9]{3}$" },
                  "category": { "type": "string", "enum": ["security", "performance", "best-practice"] },
                  "location": { "type": "string", "pattern": "^.+:\\d+$" },
                  "fix": { "type": "string", "minLength": 10 }
                },
                "required": ["id", "category", "location", "fix"]
              }
            }
          },
          "required": ["issues"]
        }
      },
      "required": ["status", "data"]
    },
    {
      "type": "object",
      "properties": {
        "status": { "type": "string", "enum": ["failed"] },
        "reason": { "type": "string" },
        "retryable": { "type": "boolean" },
        "stage": { "type": "string", "enum": ["docker-ci-review"] },
        "attempt": { "type": "integer", "minimum": 1 }
      },
      "required": ["status", "reason", "retryable", "stage", "attempt"]
    }
  ]
}
